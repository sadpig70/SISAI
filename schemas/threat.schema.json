{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SISAI threat (attack method / case)",
  "type": "object",
  "required": ["threat_id", "title", "category"],
  "properties": {
    "threat_id": {"type": "string"},
    "title": {"type": "string"},
    "category": {"type": "string"},
    "techniques": {"type": "array", "items": {"type": "string"}},
    "cve": {"type": ["string", "null"]},
    "cvss": {"type": ["number", "null"], "minimum": 0, "maximum": 10},
    "recency": {"type": ["string", "null"], "pattern": "^[0-9]{4}-[0-9]{2}(-[0-9]{2})?$"},
    "source_channels": {"type": "array", "items": {"type": "string"}},
    "evidence": {"type": "array", "items": {"type": "string"}},
    "provenance": {
      "type": ["object", "null"],
      "properties": {
        "source_url": {"type": "string"},
        "authority": {"type": ["string", "null"], "enum": ["NVD", "MITRE", "GHSA", "arXiv", null]},
        "source_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "verified": {"type": "boolean"},
        "verified_on": {"type": ["string", "null"], "pattern": "^[0-9]{4}-[0-9]{2}(-[0-9]{2})?$"}
      }
    },
    "fingerprint": {"type": "string"}
  }
}
